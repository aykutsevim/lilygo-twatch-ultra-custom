#pragma once
// Copy to secrets.h (git-ignored) to pre-seed a dev unit so it can connect
// without on-watch provisioning. NVS values, once provisioned, take precedence.

#define DEFAULT_API_BASE "https://your-app.onrender.com"
#define DEFAULT_WS_BASE "wss://your-app.onrender.com"
#define DEFAULT_API_KEY "change-me-to-a-long-random-string"

#define DEFAULT_WIFI_SSID "your-wifi"
#define DEFAULT_WIFI_PASS "your-wifi-password"

// 0 = validate TLS cert (pin a CA in ApiClient/NotesSocket); 1 = insecure dev.
#define TLS_INSECURE 1
