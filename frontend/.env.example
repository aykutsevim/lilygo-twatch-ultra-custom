# Frontend build-time config (Vite exposes import.meta.env.VITE_*).
# Absolute backend URLs. Leave VITE_API_BASE / VITE_WS_BASE empty to use the
# Vite dev proxy (same-origin /api + /ws).
VITE_API_BASE=http://localhost:8000
VITE_WS_BASE=ws://localhost:8000
# Must equal the backend's API_KEY. Not a real secret in-browser (single-user).
VITE_API_KEY=change-me-to-a-long-random-string
